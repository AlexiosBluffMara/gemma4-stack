# Copy to .env and fill in values

# Heavy tier context window (reduce if OOM)
HEAVY_CTX_SIZE=4096

# Threads for heavy tier CPU inference (set to your CPU core count)
HEAVY_THREADS=8

# Tailscale auth key (optional — for Tailscale sidecar pattern)
# Get from: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=

# Optional: Hugging Face token for faster/authenticated downloads
HF_TOKEN=
